<?xml version="1.0"?>
<robot name="simple_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>

  <xacro:property name="wheel_radius" value="0.1"/>
  <xacro:property name="wheel_width" value="0.05"/>
  <xacro:property name="wheel_offset_y" value="0.225"/>

  <link name="base_link">
    <visual>
      <origin xyz="0.0 0.0 0.05" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.5 0.4 0.1"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <xacro:macro name="wheel" params="name y_offset">
    <link name="${name}_link">
      <visual>
        <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"/>
      </visual>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_link"/>
      <origin xyz="0.0 ${y_offset} 0.0" rpy="0.0 0.0 0.0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel name="left_wheel" y_offset="${wheel_offset_y}"/>
  <xacro:wheel name="right_wheel" y_offset="${-wheel_offset_y}"/>

</robot>